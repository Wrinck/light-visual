{
  "name": "optics-lab",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "lint-staged": {
    "src/**/*.{ts,tsx,js,css,md,json}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.59.1",
    "vite": "^5.4.10",
    "vitest": "^4.1.5"
  }
}
